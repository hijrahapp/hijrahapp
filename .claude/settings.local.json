{
  "permissions": {
    "allow": [
      "Bash(command -v ruflo)",
      "Bash(ruflo --version)",
      "Bash(echo \"ruflo: $\\(command -v ruflo\\) -> $\\(ruflo --version \\)\")",
      "Bash(claude mcp *)",
      "Bash(php -v)",
      "Bash(composer install *)",
      "Bash(npm install *)",
      "mcp__ruflo__swarm_init",
      "Bash(docker start *)",
      "Bash(docker port *)",
      "Bash(docker exec *)",
      "Bash(cp .env.example .env)",
      "Bash(sed -i '' 's|^APP_KEY=.*|APP_KEY=|' .env)",
      "Bash(sed -i '' 's|^DB_HOST=.*|DB_HOST=127.0.0.1|' .env)",
      "Bash(sed -i '' 's|^DB_PASSWORD=.*|DB_PASSWORD=password|' .env)",
      "Bash(sed -i '' 's|^JWT_SECRET=.*|JWT_SECRET=base64changemelocaldevsecretkey1234567890|' .env)",
      "Bash(php artisan *)",
      "Bash(grep -oE \"menu-title[^>]*>[^<]+|>[A-Za-z][A-Za-z &/]{2,30}<\" resources/views/livewire/homepage/shared/sidebar.blade.php)",
      "Bash(grep -v \"^>$\")",
      "Bash(npm run *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://127.0.0.1:8123/app/login)",
      "Bash(break)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\\\\n\" -L http://127.0.0.1:8123/)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\\\\n\" http://127.0.0.1:8123/api/interest/all)",
      "Bash(curl -s -X POST http://127.0.0.1:8123/api/auth/login -H \"Content-Type: application/json\" -H \"Accept: application/json\" -d '{\"email\":\"testadmin1@gmail.com\",\"password\":\"password\"}')",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_take_screenshot",
      "Bash(ls .claude/settings*.json)",
      "Bash(grep -i \"attribution\" .claude/settings*.json)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "laravel-boost"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_TOOL_FILE\" =~ (routes/api\\.php|app/Http/Controllers/.*\\.php|app/Swagger/.*\\.php|app/Resources/.*\\.php) ]]; then echo '🔄 Regenerating Swagger documentation due to API changes...'; php artisan l5-swagger:generate --no-interaction; fi"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff || say 'Task completed'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Ping.aiff || say 'Permission required'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Submarine.aiff || say 'Agent stopped'"
          }
        ]
      }
    ]
  }
}
